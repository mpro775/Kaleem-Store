{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kaleem.store/schemas/storefront-theme-config-v2.json",
  "title": "Storefront Theme Config v2",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "globals",
    "sections"
  ],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "const": 2
    },
    "globals": {
      "$ref": "#/$defs/globals"
    },
    "layout": {
      "$ref": "#/$defs/layout"
    },
    "sections": {
      "type": "array",
      "minItems": 1,
      "maxItems": 40,
      "items": {
        "$ref": "#/$defs/section"
      }
    }
  },
  "$defs": {
    "hexColor": {
      "type": "string",
      "pattern": "^#(?:[0-9a-fA-F]{3}|[0-9a-fA-F]{6})$"
    },
    "fontFamily": {
      "type": "string",
      "minLength": 3,
      "maxLength": 120
    },
    "globals": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "color",
        "typography",
        "radius",
        "spacing",
        "motion"
      ],
      "properties": {
        "color": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "bg",
            "surface",
            "text",
            "textMuted",
            "primary",
            "accent",
            "danger"
          ],
          "properties": {
            "bg": { "$ref": "#/$defs/hexColor" },
            "surface": { "$ref": "#/$defs/hexColor" },
            "text": { "$ref": "#/$defs/hexColor" },
            "textMuted": { "$ref": "#/$defs/hexColor" },
            "primary": { "$ref": "#/$defs/hexColor" },
            "accent": { "$ref": "#/$defs/hexColor" },
            "danger": { "$ref": "#/$defs/hexColor" }
          }
        },
        "typography": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "bodyFontFamily",
            "headingFontFamily",
            "baseFontSize"
          ],
          "properties": {
            "bodyFontFamily": { "$ref": "#/$defs/fontFamily" },
            "headingFontFamily": { "$ref": "#/$defs/fontFamily" },
            "baseFontSize": {
              "type": "number",
              "minimum": 14,
              "maximum": 20
            }
          }
        },
        "radius": {
          "type": "object",
          "additionalProperties": false,
          "required": ["sm", "md", "lg"],
          "properties": {
            "sm": { "type": "integer", "minimum": 0, "maximum": 24 },
            "md": { "type": "integer", "minimum": 0, "maximum": 32 },
            "lg": { "type": "integer", "minimum": 0, "maximum": 48 }
          }
        },
        "spacing": {
          "type": "object",
          "additionalProperties": false,
          "required": ["unit"],
          "properties": {
            "unit": { "type": "integer", "minimum": 4, "maximum": 12 }
          }
        },
        "motion": {
          "type": "object",
          "additionalProperties": false,
          "required": ["enabled", "durationFast", "durationBase"],
          "properties": {
            "enabled": { "type": "boolean" },
            "durationFast": { "type": "integer", "minimum": 80, "maximum": 220 },
            "durationBase": { "type": "integer", "minimum": 120, "maximum": 360 }
          }
        }
      }
    },
    "layout": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "contentMaxWidth": {
          "type": "integer",
          "minimum": 960,
          "maximum": 1440
        },
        "headerSticky": {
          "type": "boolean"
        }
      }
    },
    "block": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "type", "settings"],
      "properties": {
        "id": { "type": "string", "minLength": 1, "maxLength": 80 },
        "type": { "type": "string", "minLength": 1, "maxLength": 60 },
        "settings": { "type": "object", "additionalProperties": true }
      }
    },
    "sectionBase": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "type", "enabled", "settings"],
      "properties": {
        "id": { "type": "string", "minLength": 1, "maxLength": 80 },
        "type": { "type": "string" },
        "enabled": { "type": "boolean" },
        "variant": { "type": "string", "maxLength": 60 },
        "settings": { "type": "object", "additionalProperties": true },
        "blocks": {
          "type": "array",
          "maxItems": 24,
          "items": { "$ref": "#/$defs/block" }
        }
      }
    },
    "announcementSection": {
      "allOf": [
        { "$ref": "#/$defs/sectionBase" },
        {
          "properties": {
            "type": { "const": "announcement_bar" },
            "settings": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "message": { "type": "string", "minLength": 1, "maxLength": 240 }
              }
            }
          }
        }
      ]
    },
    "heroSection": {
      "allOf": [
        { "$ref": "#/$defs/sectionBase" },
        {
          "properties": {
            "type": { "const": "hero" },
            "settings": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "headline": { "type": "string", "minLength": 1, "maxLength": 180 },
                "subheadline": { "type": "string", "maxLength": 320 },
                "primaryCtaLabel": { "type": "string", "maxLength": 40 },
                "primaryCtaHref": { "type": "string", "maxLength": 300 }
              }
            }
          }
        }
      ]
    },
    "genericSection": {
      "allOf": [
        { "$ref": "#/$defs/sectionBase" },
        {
          "properties": {
            "type": {
              "enum": [
                "header",
                "categories_grid",
                "featured_products",
                "rich_text",
                "testimonials",
                "newsletter_signup",
                "offers_banner",
                "faq",
                "trust_badges",
                "footer"
              ]
            }
          }
        }
      ]
    },
    "section": {
      "oneOf": [
        { "$ref": "#/$defs/announcementSection" },
        { "$ref": "#/$defs/heroSection" },
        { "$ref": "#/$defs/genericSection" }
      ]
    }
  }
}
