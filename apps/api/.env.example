NODE_ENV=development
PORT=3000

DATABASE_URL=postgres://kaleem:kaleem123@localhost:5432/kaleem_store
REDIS_URL=redis://localhost:6379

RABBITMQ_URL=amqp://guest:guest@localhost:5672
RABBITMQ_EXCHANGE=kaleem.events
NOTIFICATIONS_MAIN_QUEUE=notifications.order-events
NOTIFICATIONS_DLQ_QUEUE=notifications.order-events.dlq
NOTIFICATIONS_RETRY_CREATED_QUEUE=notifications.order-created.retry
NOTIFICATIONS_RETRY_STATUS_QUEUE=notifications.order-status.retry
NOTIFICATIONS_RETRY_INVENTORY_QUEUE=notifications.inventory.retry
NOTIFICATIONS_MAX_RETRIES=3
NOTIFICATIONS_RETRY_DELAY_MS=10000
INVENTORY_RESERVATION_TTL_MINUTES=15
THEME_PREVIEW_TOKEN_TTL_MINUTES=30
DOMAIN_VERIFY_TXT_PREFIX=_kaleem-verify
DOMAIN_CNAME_TARGET=stores.example.com
DOMAIN_SSL_PROVIDER=manual
DOMAIN_SSL_MODE=full_strict
CLOUDFLARE_API_BASE_URL=https://api.cloudflare.com/client/v4
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_SSL_VALIDATION_METHOD=txt
CLOUDFLARE_MIN_TLS_VERSION=1.2
CLOUDFLARE_TLS_CIPHERS=
PLATFORM_ADMIN_SECRET=kaleem-local-platform-secret

JWT_ACCESS_SECRET=kaleem-local-access-secret-change-me
JWT_ACCESS_EXPIRES_IN=15m
REFRESH_TOKEN_TTL_DAYS=30
AUTH_OTP_SECRET=kaleem-local-owner-registration-otp-secret-change-me
AUTH_OTP_TTL_MINUTES=10
AUTH_OTP_MAX_VERIFY_ATTEMPTS=5
AUTH_OTP_RESEND_COOLDOWN_SECONDS=60
AUTH_OTP_MAX_RESEND_COUNT=5

EMAIL_DELIVERY_MODE=log
EMAIL_FROM=no-reply@kaleem.store
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
RESEND_API_BASE_URL=https://api.resend.com
RESEND_API_KEY=

S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=kaleem-media
S3_ACCESS_KEY=minio
S3_SECRET_KEY=minio123
S3_FORCE_PATH_STYLE=true
S3_PUBLIC_BASE_URL=http://localhost:9000/kaleem-media
S3_PRESIGNED_PUT_TTL_SECONDS=900
S3_PRESIGNED_GET_TTL_SECONDS=600

ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3001
CSRF_ENABLED=false
