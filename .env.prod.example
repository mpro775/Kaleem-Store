# Core runtime
NODE_ENV=production
PORT=3000

# Postgres (container bootstrap)
POSTGRES_USER=kaleem
POSTGRES_PASSWORD=replace_with_strong_password
POSTGRES_DB=kaleem_store

# pgAdmin (internal web UI, publish through Nginx Proxy Manager only)
PGADMIN_DEFAULT_EMAIL=ops@example.com
PGADMIN_DEFAULT_PASSWORD=replace_with_strong_pgadmin_password

# Internal service connections
DATABASE_URL=postgres://kaleem:replace_with_strong_password@postgres:5432/kaleem_store
REDIS_URL=redis://redis:6379
RABBITMQ_URL=amqp://kaleem_rabbit:replace_with_strong_password@rabbitmq:5672

# RabbitMQ topology
RABBITMQ_DEFAULT_USER=kaleem_rabbit
RABBITMQ_DEFAULT_PASS=replace_with_strong_password
RABBITMQ_EXCHANGE=kaleem.events
NOTIFICATIONS_MAIN_QUEUE=notifications.order-events
NOTIFICATIONS_DLQ_QUEUE=notifications.order-events.dlq
NOTIFICATIONS_RETRY_CREATED_QUEUE=notifications.order-created.retry
NOTIFICATIONS_RETRY_STATUS_QUEUE=notifications.order-status.retry
NOTIFICATIONS_RETRY_INVENTORY_QUEUE=notifications.inventory.retry
NOTIFICATIONS_MAX_RETRIES=3
NOTIFICATIONS_RETRY_DELAY_MS=10000

# Auth and platform secrets (set long random values)
JWT_ACCESS_SECRET=replace_with_very_long_random_secret
JWT_ACCESS_EXPIRES_IN=15m
REFRESH_TOKEN_TTL_DAYS=30
AUTH_OTP_SECRET=replace_with_very_long_random_secret
AUTH_OTP_TTL_MINUTES=10
AUTH_OTP_MAX_VERIFY_ATTEMPTS=5
AUTH_OTP_RESEND_COOLDOWN_SECONDS=60
AUTH_OTP_MAX_RESEND_COUNT=5
PLATFORM_ADMIN_SECRET=replace_with_very_long_random_secret
WEBHOOK_SECRET=replace_with_very_long_random_secret

# Email delivery (set smtp or resend)
EMAIL_DELIVERY_MODE=smtp
EMAIL_FROM=info@kaleemstores.com
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=info@kaleemstores.com
SMTP_PASS=replace_with_email_app_password
RESEND_API_BASE_URL=https://api.resend.com
RESEND_API_KEY=

# App behavior
INVENTORY_RESERVATION_TTL_MINUTES=15
THEME_PREVIEW_TOKEN_TTL_MINUTES=30
DOMAIN_VERIFY_TXT_PREFIX=_kaleem-verify
DOMAIN_CNAME_TARGET=stores.kaleemstores.com
DOMAIN_SSL_MODE=full_strict

# CORS / security
ALLOWED_ORIGINS=https://kaleemstores.com,https://www.kaleemstores.com
CSRF_ENABLED=true

# Cloudflare R2 (S3-compatible)
S3_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
S3_REGION=auto
S3_BUCKET=your-r2-bucket
S3_ACCESS_KEY=your-r2-access-key-id
S3_SECRET_KEY=your-r2-secret-access-key
S3_FORCE_PATH_STYLE=false
S3_PUBLIC_BASE_URL=https://pub-your-bucket-id.r2.dev
S3_PRESIGNED_PUT_TTL_SECONDS=900
S3_PRESIGNED_GET_TTL_SECONDS=600

# Optional observability
SENTRY_DSN=
SENTRY_RELEASE=0.1.0
METRICS_PREFIX=kaleem_

# Optional queue health script settings
RABBITMQ_MANAGEMENT_URL=http://rabbitmq:15672
RABBITMQ_MANAGEMENT_USER=kaleem_rabbit
RABBITMQ_MANAGEMENT_PASSWORD=replace_with_strong_password
NOTIFICATIONS_MAIN_QUEUE_MAX_MESSAGES=200
NOTIFICATIONS_DLQ_QUEUE_MAX_MESSAGES=0
